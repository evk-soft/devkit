{
  "name": "@evk-soft/devkit",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "devEngines": {
    "runtime": [
      { "name": "node", "version": ">=24.0.0" },
      { "name": "bun", "version": ">=1.3.0" }
    ]
  },
  "scripts": {
    "check": "pnpm run check:biome && pnpm run check:runtime",
    "check:biome": "biome check .",
    "check:runtime": "node ./scripts/runtime-check.mjs",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3"
  }
}

